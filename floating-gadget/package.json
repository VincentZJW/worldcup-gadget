{
  "name": "worldcup-floating-gadget",
  "version": "1.0.0",
  "private": true,
  "description": "A local macOS floating World Cup results gadget.",
  "author": "VincentZJW",
  "main": "main.js",
  "scripts": {
    "postinstall": "node scripts/install-electron-binary.js",
    "electron:install": "node scripts/install-electron-binary.js",
    "prestart": "node scripts/check-electron.js",
    "start": "electron .",
    "predev": "node scripts/check-electron.js",
    "dev": "electron .",
    "package:mac": "electron-builder --mac dir",
    "dist:mac": "npm run package:mac && node scripts/create-mac-dmg.js"
  },
  "build": {
    "appId": "com.vincent.worldcup.gadget",
    "productName": "WorldCup Gadget",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../data/latest.json",
        "to": "data/latest.json"
      }
    ],
    "mac": {
      "category": "public.app-category.sports",
      "identity": null,
      "target": [
        "dir"
      ]
    }
  },
  "devDependencies": {
    "electron": "^42.4.1",
    "electron-builder": "^26.0.12"
  }
}
